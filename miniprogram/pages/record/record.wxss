/* pages/record/record.wxss */
.page-record {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--c-bg);
  padding: 0 28rpx;
  box-sizing: border-box;
}

/* === Mask === */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(43,54,57,0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
}
.privacy-modal {
  background: var(--c-surface);
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  width: 100%;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.15);
}
.pm-title {
  font-size: 36rpx;
  font-weight: 500;
  color: var(--c-text);
  margin-bottom: 20rpx;
}
.pm-body {
  font-size: 27rpx;
  color: var(--c-muted);
  line-height: 1.7;
  margin-bottom: 36rpx;
}
.pm-btns {
  display: flex;
  gap: 16rpx;
}
.pm-btns .btn-primary,
.pm-btns .btn-outline {
  flex: 1;
  padding: 22rpx 0;
  font-size: 29rpx;
}

/* === Content === */
.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 36rpx;
}

/* === Role Tag === */
.role-tag {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 24rpx;
  align-self: flex-start;
}
.rt-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--c-brand);
}
.rt-label {
  font-size: 26rpx;
  color: var(--c-brand);
  font-weight: 450;
  letter-spacing: 2rpx;
}

/* === Time Display === */
.time-display {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 20rpx;
}
.td-num {
  font-size: 112rpx;
  font-weight: 200;
  color: var(--c-text);
  letter-spacing: -4rpx;
  font-feature-settings: "tnum";
  font-variant-numeric: tabular-nums;
}
.td-unit {
  font-size: 32rpx;
  color: var(--c-muted);
}

/* === Wave Bar === */
.wave-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 60rpx;
  margin-bottom: 28rpx;
}
.wb-seg {
  width: 6rpx;
  border-radius: 6rpx;
  background: var(--c-accent);
  transition: height 0.3s ease;
}
.wave-bar.active .wb-seg {
  animation: wave-pulse 0.8s ease-in-out infinite alternate;
}
.wave-bar.active .wb-seg:nth-child(2)  { animation-delay: 0.1s; }
.wave-bar.active .wb-seg:nth-child(3)  { animation-delay: 0.2s; }
.wave-bar.active .wb-seg:nth-child(4)  { animation-delay: 0.3s; }
.wave-bar.active .wb-seg:nth-child(5)  { animation-delay: 0.4s; }
.wave-bar.active .wb-seg:nth-child(6)  { animation-delay: 0.15s; }
.wave-bar.active .wb-seg:nth-child(7)  { animation-delay: 0.25s; }

@keyframes wave-pulse {
  from { height: 14rpx; background: var(--c-accent); }
  to   { height: 56rpx; background: var(--c-brand-light); }
}

/* === Phase Hint === */
.phase-hint {
  font-size: 26rpx;
  color: var(--c-muted);
  margin-bottom: 32rpx;
  height: 36rpx;
}

/* === Footer / Action Area === */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  margin-top: auto;
  padding-bottom: 40rpx;
  width: 100%;
}

/* Replay row (only when recorded) */
.replay-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.replay-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 28rpx;
  background: rgba(212,237,230,0.25);
  border-radius: 40rpx;
  border: 1.5rpx solid var(--c-accent);
}
.play-icon {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.play-tri {
  width: 0;
  height: 0;
  border-left: 18rpx solid var(--c-brand);
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
}
.pause-bars {
  display: flex;
  gap: 5rpx;
  align-items: center;
}
.pause-bars .bar {
  width: 6rpx;
  height: 22rpx;
  background: var(--c-brand);
  border-radius: 4rpx;
}
.replay-label {
  font-size: 27rpx;
  color: var(--c-brand);
  font-weight: 450;
}
.replay-time {
  font-size: 26rpx;
  color: var(--c-muted);
  font-variant-numeric: tabular-nums;
}
.rt-cur { color: var(--c-text); }

/* Main action area */
.main-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  width: 100%;
}

/* Reset and Upload buttons */
.btn-outline,
.btn-primary {
  width: 100%;
  max-width: 480rpx;
}
.btn-outline {
  background: transparent;
  color: var(--c-brand);
  border: 2rpx solid var(--c-brand-light);
  border-radius: 48rpx;
  font-size: 28rpx;
  padding: 18rpx 0;
  text-align: center;
}
button.btn-outline::after { border: none; }

.btn-primary {
  background: var(--c-brand);
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
  padding: 24rpx 0;
  text-align: center;
}
button.btn-primary::after { border: none; }

.uploading-state {
  width: 100%;
  max-width: 480rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: var(--c-accent);
  display: flex;
  align-items: center;
  justify-content: center;
}
.up-text {
  font-size: 29rpx;
  color: var(--c-brand);
}

/* Record control (big circle) */
.record-control {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.record-inner {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--c-brand);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s ease;
}
.record-inner:active {
  transform: scale(0.95);
}
.record-inner.recording {
  background: var(--c-warn);
}
.record-inner.recorded {
  background: var(--c-muted);
}
.record-wave {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.9);
}
.record-wave.active {
  animation: wave-pulse-inner 1.5s ease-in-out infinite;
}
@keyframes wave-pulse-inner {
  from { transform: scale(0.8); opacity: 0.6; }
  to   { transform: scale(1.2); opacity: 0.3; }
}
.record-label {
  position: absolute;
  bottom: -24rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 24rpx;
  color: var(--c-muted);
  white-space: nowrap;
}

/* Ensure safe area */
@media screen and (min-device-width: 360px) and (max-device-width: 640px) and (-webkit-device-pixel-ratio: 2) and (orientation: portrait) {
  .page-record { padding-bottom: env(safe-area-inset-bottom); }
}