<!-- pages/report/report.wxml — 报告页 -->
<view class="page-report" wx:if="{{hasReport}}">
  <view class="report-header">
    <text class="rh-label">比对报告</text>
    <text class="rh-sub">{{reportDate}}</text>
  </view>

  <!-- Canvas 报告图 -->
  <view class="canvas-wrap">
    <canvas type="2d" id="reportCanvas" class="canvas"></canvas>
  </view>

  <!-- 操作按钮 -->
  <view class="action-row">
    <button class="btn-primary btn-save" bindtap="saveImage">
      <text class="btn-icon">⤴</text> 保存图片
    </button>
    <button class="btn-outline btn-again" bindtap="goRecord">再做一次</button>
  </view>

  <text class="share-hint">点击右上角「···」可分享给好友或朋友圈</text>
</view>

<!-- 无报告空状态 -->
<view class="page-empty" wx:else>
  <view class="empty-illust">
    <view class="ei-ring"></view>
    <view class="ei-dot"></view>
  </view>
  <text class="empty-title">暂无报告</text>
  <text class="empty-sub">请先完成咨询师与来访者的音色录制</text>
  <button class="btn-primary" bindtap="goRecord">去录制音色</button>
</view>