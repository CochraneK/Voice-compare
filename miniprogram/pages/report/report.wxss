/* pages/report/report.wxss — 报告页 */
.page-report, .page-empty {
  background: var(--c-bg);
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 28rpx;
}

/* === header === */
.report-header {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 28rpx;
  padding-top: 16rpx;
}
.rh-label {
  font-size: 36rpx;
  font-weight: 450;
  color: var(--c-text);
}
.rh-sub {
  font-size: 24rpx;
  color: var(--c-muted);
}

/* === canvas === */
.canvas-wrap {
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(74,124,143,0.08);
  background: var(--c-surface);
}
.canvas {
  width: 100%;
  height: 900px;
}

/* === buttons === */
.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
  padding: 0 8rpx;
}
.btn-save, .btn-again {
  flex: 1;
}
.btn-icon {
  font-size: 28rpx;
  margin-right: 4rpx;
}
.share-hint {
  display: block;
  text-align: center;
  margin-top: 28rpx;
  font-size: 24rpx;
  color: var(--c-muted);
  line-height: 1.6;
}

/* === empty === */
.page-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 120rpx;
  gap: 16rpx;
}
.empty-illust {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 16rpx;
}
.ei-ring {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid var(--c-accent);
}
.ei-dot {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%,-50%);
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: var(--c-brand);
}
.empty-title {
  font-size: 32rpx;
  font-weight: 450;
  color: var(--c-text);
}
.empty-sub {
  font-size: 25rpx;
  color: var(--c-muted);
  margin-bottom: 20rpx;
}