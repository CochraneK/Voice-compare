/* pages/index/index.wxss — 治疗感首页 */
.page-home {
  padding-top: 12rpx;
  padding-bottom: 40rpx;
}

/* === Hero === */
.hero {
  margin: 28rpx 28rpx 10rpx;
  position: relative;
}
.hero-line {
  width: 40rpx;
  height: 4rpx;
  background: var(--c-accent);
  border-radius: 4rpx;
  margin-bottom: 12rpx;
}
.hero-line.right {
  margin-left: auto;
  margin-top: 16rpx;
  height: 3rpx;
  width: 60rpx;
}
.hero-text {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}
.hero-title {
  font-size: 60rpx;
  font-weight: 300;
  color: var(--c-brand);
  letter-spacing: 4rpx;
}
.hero-title-sub {
  font-size: 38rpx;
  font-weight: 350;
  color: var(--c-brand-light);
}
.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--c-muted);
  line-height: 1.6;
}

/* === Persona Card === */
.persona-card {
  background: var(--c-surface);
  border-radius: 20rpx;
  margin: 24rpx 28rpx;
  padding: 36rpx 32rpx 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(74,124,143,0.06);
  border-left: 6rpx solid transparent;
}
.pc-status {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 14rpx;
}
.pc-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--c-accent);
  flex-shrink: 0;
}
.pc-dot.active {
  background: var(--c-positive);
  box-shadow: 0 0 8rpx rgba(90,157,122,0.4);
}
.pc-dot.inactive {
  background: var(--c-muted);
  opacity: 0.45;
}
.pc-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.pc-role {
  font-size: 32rpx;
  font-weight: 450;
  color: var(--c-text);
}
.pc-state {
  font-size: 24rpx;
  color: var(--c-muted);
}
.pc-desc {
  font-size: 24rpx;
  color: var(--c-muted);
  line-height: 1.5;
  margin-bottom: 24rpx;
  padding-left: 34rpx;
}

.persona-card .btn-primary,
.persona-card .btn-ghost {
  margin: 0;
}

/* === Footer === */
.footer-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  margin-top: 32rpx;
}
.footer-link {
  font-size: 24rpx;
  color: var(--c-muted);
}
.footer-dot {
  font-size: 24rpx;
  color: var(--c-accent);
}